---
import { Image } from "astro:assets";
import DemoNotice from "../components/DemoNotice.astro";
import atmosphereImage from "../assets/images/ristorante-demo/atmosphere/tavolo-ristorante-mediterraneo-demo.webp";
import { imagePlaceholdersById } from "../data/imagePlaceholders.js";
import BaseLayout from "../layouts/BaseLayout.astro";

const atmosphere = imagePlaceholdersById["atmosphere-table"];
---

<BaseLayout
  title="Il ristorante demo"
  description="Concept dimostrativo per un ristorante di pesce contemporaneo, progettato per mostrare UX, contenuti, accessibilità e identità visiva in un sito vetrina locale."
>
  <header class="content-hero">
    <div class="content-hero__inner container">
      <div class="content-hero__content flow">
        <p class="eyebrow">Identità e contenuti</p>
        <h1>Un concept demo per un ristorante di pesce contemporaneo</h1>
        <p class="content-hero__lead">
          Una pagina pensata per mostrare come raccontare un ristorante locale
          con una voce chiara, una gerarchia leggibile e un’identità visiva
          coerente.
        </p>
      </div>
      <Image
        class="content-hero__image"
        src={atmosphereImage}
        alt={atmosphere.alt}
        widths={[480, 720, 800, 960]}
        sizes="(min-width: 48rem) 42vw, 100vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </header>

  <div class="demo-strip container">
    <DemoNotice headingId="restaurant-demo-notice-title" />
  </div>

  <section class="section" aria-labelledby="concept-title">
    <div class="narrow container flow">
      <p class="eyebrow">Il concept</p>
      <h2 id="concept-title">Raccontare un’identità locale senza costruire una finzione</h2>
      <p class="section__lead">
        Azzurro di Mare immagina una cucina di pesce contemporanea come base per
        un caso studio frontend. Il contenuto definisce tono, proposta e
        atmosfera, ma chiarisce sempre che il ristorante non è un’attività
        realmente operativa.
      </p>
      <p>
        Questa impostazione permette di valutare architettura informativa,
        qualità editoriale e coerenza visiva senza ricorrere a indirizzi,
        recensioni o promesse commerciali inventate.
      </p>
    </div>
  </section>

  <section class="section section--surface" aria-labelledby="cuisine-title">
    <div class="feature-grid container">
      <div class="feature-card flow">
        <p class="eyebrow">Cucina mediterranea</p>
        <h2 id="cuisine-title">Un menu breve, leggibile e credibile</h2>
        <p>
          La proposta demo utilizza piatti di mare e ingredienti mediterranei
          per mostrare una struttura menu semplice da consultare, soprattutto
          da smartphone.
        </p>
        <a class="text-link" href="/menu/">Esplora il menu demo di pesce</a>
      </div>

      <div class="feature-card flow">
        <p class="eyebrow">Atmosfera e identità</p>
        <h2 id="identity-title">Una direzione visiva sobria</h2>
        <p>
          Fotografie pertinenti, palette ispirata alla costa e tipografia
          editoriale definiscono il carattere del progetto senza trasformarlo
          in una brochure promozionale.
        </p>
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="mobile-title">
    <div class="narrow container flow">
      <p class="eyebrow">Esperienza mobile-first</p>
      <h2 id="mobile-title">Prima leggibile, poi distintiva</h2>
      <p class="section__lead">
        Navigazione, testi e call to action sono progettati partendo dagli
        schermi piccoli. Le informazioni restano comprensibili, i target touch
        sono comodi e nessun contenuto essenziale dipende da effetti visivi.
      </p>
      <p>
        Il risultato mostra come l’identità di un ristorante locale possa
        convivere con accessibilità, performance e percorsi semplici.
      </p>
    </div>
  </section>

  <section class="study-callout section" aria-labelledby="study-title">
    <div class="study-callout__inner container flow">
      <p class="eyebrow eyebrow--light">Approfondimento</p>
      <h2 id="study-title">Le decisioni dietro il concept</h2>
      <p>
        Il caso studio documenta struttura, contenuti, accessibilità, immagini e
        scelte tecniche usate per costruire questa identità dimostrativa.
      </p>
      <a class="button" href="/caso-studio/">Leggi il caso studio frontend</a>
    </div>
  </section>
</BaseLayout>

<style>
  .content-hero,
  .section {
    padding-block: var(--space-section);
  }

  .content-hero {
    padding-block-start: clamp(2.5rem, 7vw, 6rem);
  }

  .content-hero__inner,
  .feature-grid {
    display: grid;
    gap: var(--space-8);
  }

  .content-hero__content {
    align-self: center;
  }

  .content-hero__lead,
  .section__lead {
    font-size: var(--font-size-lg);
  }

  .content-hero__image {
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-md);
    object-fit: cover;
    box-shadow: var(--shadow-soft);
  }

  .demo-strip {
    margin-block-end: var(--space-8);
  }

  .narrow,
  .study-callout__inner {
    max-width: 52rem;
  }

  .section--surface {
    background-color: var(--color-surface);
  }

  .feature-card {
    padding: clamp(var(--space-6), 5vw, var(--space-12));
    border: 1px solid var(--color-sand-alt);
    border-radius: var(--radius-md);
    background-color: var(--color-background);
  }

  .eyebrow {
    color: var(--color-coral-text);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .eyebrow--light {
    color: var(--color-sand-alt);
  }

  .text-link {
    display: inline-flex;
    width: fit-content;
    min-height: var(--touch-target-min);
    align-items: center;
    font-weight: var(--font-weight-bold);
  }

  .study-callout {
    background-color: var(--color-petrol);
    color: var(--color-white);
  }

  .study-callout h2 {
    color: var(--color-white);
  }

  .button {
    display: inline-flex;
    width: fit-content;
    min-height: var(--touch-target-min);
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    border: 0.125rem solid var(--color-white);
    border-radius: var(--radius-sm);
    background-color: var(--color-white);
    color: var(--color-navy);
    font-weight: var(--font-weight-bold);
    text-align: center;
    text-decoration: none;
  }

  .button:hover {
    text-decoration: underline;
    text-decoration-thickness: 0.15rem;
  }

  @media (min-width: 48rem) {
    .content-hero__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 0.8fr);
      align-items: center;
      gap: clamp(var(--space-8), 6vw, var(--space-16));
    }

    .feature-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
