---
import { primaryNavigation } from "../data/navigation.js";

const currentPath = Astro.url.pathname;
const isCurrentPage = (href) =>
  href === "/" ? currentPath === href : currentPath.startsWith(href);
---

<header class="site-header">
  <div class="site-header__inner container">
    <a class="site-header__brand" href="/" aria-label="Azzurro di Mare, home">
      Azzurro di Mare
    </a>

    <details class="site-header__menu">
      <summary class="site-header__menu-toggle">
        <span class="site-header__menu-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <span>Menu</span>
      </summary>

      <nav
        class="site-header__nav site-header__nav--mobile"
        aria-label="Navigazione principale"
      >
        <ul class="site-header__list">
          {
            primaryNavigation.map(({ href, label }) => (
              <li>
                <a
                  class="site-header__link"
                  href={href}
                  aria-current={isCurrentPage(href) ? "page" : undefined}
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </details>

    <nav
      class="site-header__nav site-header__nav--desktop"
      aria-label="Navigazione principale"
    >
      <ul class="site-header__list">
        {
          primaryNavigation.map(({ href, label }) => (
            <li>
              <a
                class="site-header__link"
                href={href}
                aria-current={isCurrentPage(href) ? "page" : undefined}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-block-end: 1px solid var(--color-sand-alt);
    background-color: var(--color-surface);
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-4);
    align-items: center;
    padding-block: var(--space-4);
  }

  .site-header__brand {
    width: fit-content;
    color: var(--color-navy);
    font-family: var(--font-heading);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-heading);
    text-decoration: none;
  }

  .site-header__menu {
    display: contents;
  }

  .site-header__menu-toggle {
    display: inline-flex;
    min-height: var(--touch-target-min);
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-sand-alt);
    border-radius: var(--radius-sm);
    color: var(--color-navy);
    cursor: pointer;
    font-weight: var(--font-weight-bold);
    list-style: none;
  }

  .site-header__menu-toggle::-webkit-details-marker {
    display: none;
  }

  .site-header__menu-toggle:focus-visible {
    outline: 0.15rem solid transparent;
    box-shadow: var(--focus-ring);
  }

  .site-header__menu-icon {
    display: grid;
    width: 1.25rem;
    gap: 0.22rem;
  }

  .site-header__menu-icon span {
    height: 0.125rem;
    border-radius: var(--radius-sm);
    background-color: currentColor;
  }

  .site-header__menu[open] .site-header__menu-icon span:nth-child(1) {
    transform: translateY(0.345rem) rotate(45deg);
  }

  .site-header__menu[open] .site-header__menu-icon span:nth-child(2) {
    opacity: 0;
  }

  .site-header__menu[open] .site-header__menu-icon span:nth-child(3) {
    transform: translateY(-0.345rem) rotate(-45deg);
  }

  .site-header__nav {
    grid-column: 1 / -1;
  }

  .site-header__nav--desktop {
    display: none;
  }

  .site-header__list {
    display: grid;
    gap: var(--space-1);
    padding-block-start: var(--space-2);
  }

  .site-header__link {
    display: flex;
    align-items: center;
    min-height: var(--touch-target-min);
    padding-inline: var(--space-2);
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
  }

  .site-header__link:hover,
  .site-header__link[aria-current="page"] {
    color: var(--color-petrol);
    text-decoration: underline;
    text-decoration-color: var(--color-gold);
    text-decoration-thickness: 0.15rem;
  }

  @media (min-width: 64rem) {
    .site-header__inner {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .site-header__menu-toggle {
      display: none;
    }

    .site-header__menu {
      display: none;
    }

    .site-header__nav--desktop {
      display: block;
      grid-column: 2;
      justify-self: end;
    }

    .site-header__list {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2) var(--space-4);
      padding-block-start: 0;
    }

    .site-header__link {
      padding-inline: 0;
    }
  }
</style>
